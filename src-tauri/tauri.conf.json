{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Freally Capture",
  "identifier": "com.freally.capture",
  "mainBinaryName": "freally-capture",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Freally Capture",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; media-src 'self' blob:; connect-src ipc: http://ipc.localhost preview: http://preview.localhost wss://0.peerjs.com https://0.peerjs.com"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["freally"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "app", "dmg", "appimage", "deb", "rpm"],
    "category": "Video",
    "shortDescription": "Local-first live-streaming & recording studio.",
    "longDescription": "Freally Capture is a local-first, cross-platform live-streaming and recording studio: scenes and sources composed on an owned GPU compositor, multi-track recording, and direct-to-platform broadcasting — no accounts, no telemetry, no cloud.",
    "homepage": "https://mikesruthless12.github.io/freally-capture/",
    "publisher": "Havoc Software",
    "copyright": "© 2026 Mike Weaver — All Rights Reserved",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" }
    },
    "macOS": {
      "minimumSystemVersion": "12.3",
      "signingIdentity": "-",
      "hardenedRuntime": true
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3"]
      }
    }
  }
}
