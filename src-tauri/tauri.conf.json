{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Freally Capture",
  "identifier": "com.freally.capture",
  "mainBinaryName": "freally-capture",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Freally Capture",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; media-src 'self' blob:; connect-src ipc: http://ipc.localhost preview: http://preview.localhost wss://0.peerjs.com https://0.peerjs.com"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["freally"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkxRjhGMTdEQjFFRURCMDcKUldRSDIrNnhmZkg0a1RZb05NQTRwNlFMUE1FQWRmRm0xS2UrWWJlQmJDcFdXT0syTGpPZmdNaDUK",
      "endpoints": [
        "https://github.com/MikesRuthless12/freally-capture/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "basicUi"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis", "app", "dmg", "appimage", "deb", "rpm"],
    "category": "Video",
    "shortDescription": "Local-first live-streaming & recording studio.",
    "longDescription": "Freally Capture is a local-first, cross-platform live-streaming and recording studio: scenes and sources composed on an owned GPU compositor, multi-track recording, and direct-to-platform broadcasting — no accounts, no telemetry, no cloud.",
    "homepage": "https://mikesruthless12.github.io/freally-capture/",
    "publisher": "Havoc Software",
    "copyright": "© 2026 Mike Weaver — All Rights Reserved",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "icons/frec.ico",
      "icons/frec.icns",
      "icons/frec/frec.png"
    ],
    "fileAssociations": [
      {
        "ext": ["frec"],
        "name": "Freally Recording",
        "description": "Freally Capture lossless recording (freally-video)",
        "mimeType": "video/x-freally-frec",
        "role": "Editor"
      }
    ],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" },
      "wix": {
        "version": "0.231.0"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installerHooks": "nsis-hooks.nsh"
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.3",
      "signingIdentity": "-",
      "hardenedRuntime": true
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3"]
      }
    }
  }
}
